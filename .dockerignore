# Keep the Docker build context small and avoid baking local secrets/outputs
# into images. The production motifd image needs Flutter Web sources, so keep
# apps/flutter/lib + web + hook + pubspec files in the context while excluding
# platform projects and generated build/cache dirs.
.git
target
**/target

# Flutter generated/build artifacts and platform projects not needed for web.
apps/flutter/build
apps/flutter/.dart_tool
apps/flutter/.flutter-plugins*
apps/flutter/.metadata
apps/flutter/.amp
apps/flutter/android
apps/flutter/ios
apps/flutter/linux
apps/flutter/macos
apps/flutter/windows
apps/flutter/integration_test
apps/flutter/test
apps/flutter/ghostty
apps/flutter/tool
apps/flutter/scripts
apps/flutter/MOTIF_FLUTTER_PLAN.md
apps/flutter/PLAN.md
apps/flutter/devtools_options.yaml
apps/flutter/ffigen.yaml

# Logs, packaging outputs, local env
*.log
*.dmg
*.ipa
.DS_Store
.env
.env.*

# The review launcher's transient token dir, if ever created in-tree
deploy/review/*.token
